{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rusty-ai.github.io/schemas/tool_invocation.json",
  "title": "RustyAi Phase-0 tool invocation",
  "description": "Wire format matches serde externally tagged enum: {\"tool\":\"...\", ...fields }.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "path"],
      "properties": {
        "tool": { "const": "read_file" },
        "path": { "type": "string", "description": "Path relative to workspace root (executor policy)" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "path", "content"],
      "properties": {
        "tool": { "const": "write_file" },
        "path": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "argv"],
      "properties": {
        "tool": { "const": "run_cmd" },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "argv[0] = binary; remainder = arguments"
        },
        "cwd": { "type": "string", "description": "Optional working directory" }
      }
    }
  ]
}
